{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "center",
  "control-center-positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",

  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 8,
  "control-center-width": 400,
  "control-center-height": -1,
  "fit-to-screen": false,
  "notification-grouping": false,

  "notification-window-width": 400,
  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 220,
  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "image-visibility": "when-available",
  "transition-time": 200,
  "keyboard-shortcuts": true,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": [
    "title",
    "dnd",
    "mpris",
    "notifications"
  ],

  "widget-config": {
    "notifications": {
      "vexpand": false
    },

    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },

    "dnd": {
      "text": "Do Not Disturb"
    },

    "volume": {
      "label": "󰕾",
      "show-per-app": true
    },

    "mpris": {
      "image-size": 88,
      "image-radius": 12
    },

    "buttons-grid#toggles": {
      "actions": [
        {
          "label": "󰖩  Wi-Fi",
          "type": "toggle",
          "active": true,
          "command": "/home/valer/.config/swaync/toggles.sh wifi toggle",
          "update-command": "/home/valer/.config/swaync/toggles.sh wifi state"
        },
        {
          "label": "󰂯  Bluetooth",
          "type": "toggle",
          "active": true,
          "command": "/home/valer/.config/swaync/toggles.sh bt toggle",
          "update-command": "/home/valer/.config/swaync/toggles.sh bt state"
        },
        {
          "label": "󰖔  Dark Mode",
          "type": "toggle",
          "active": true,
          "command": "/home/valer/.config/swaync/toggles.sh dark toggle",
          "update-command": "/home/valer/.config/swaync/toggles.sh dark state"
        }
      ]
    },

    "buttons-grid#actions": {
      "actions": [
        {
          "label": "󰄄",
          "type": "button",
          "command": "sh -c 'sleep 0.2; niri msg action screenshot'"
        },
        {
          "label": "󰌾",
          "type": "button",
          "command": "swaylock"
        },
        {
          "label": "󰒓",
          "type": "button",
          "command": "gnome-control-center"
        },
        {
          "label": "󰐥",
          "type": "button",
          "command": "systemctl poweroff"
        }
      ]
    }
  }
}
